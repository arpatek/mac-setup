# ┌──────────────────────┐
# │ arpatek - .curlrc    │
# └──────────────────────┘
# Default flags applied to every curl invocation.
# Override any of these per-call by passing the long flag explicitly.

# Follow redirects (HTTP 301/302/307/308)
--location

# Request a compressed response (gzip/br) and decompress automatically
--compressed

# Suppress the progress meter — still shows errors (see --show-error)
--silent

# Show error messages even when --silent is set
--show-error

# Fail with exit code 22 on HTTP 4xx/5xx instead of printing the error body
--fail

# Retry up to 3 times on transient failures (connection refused, timeout)
--retry 3
--retry-delay 2
--retry-connrefused
