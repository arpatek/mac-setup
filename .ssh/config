# │ arpatek - SSH Config │
# └──────────────────────┘

# ──[ Global Defaults ]────────────────────────────────────────────────────────
# These apply to every host unless overridden in a specific Host block.

Host *
  # Connection multiplexing: reuse an existing TCP connection to the same host.
  # The first ssh opens a master socket; every subsequent ssh to that host
  # tunnels through it — near-instant reconnects and no repeated key prompts.
  ControlMaster auto
  ControlPath   ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m

  # Send a keepalive packet every 60s so the connection doesn't drop behind
  # an idle-timing NAT gateway or firewall.
  ServerAliveInterval 60
  ServerAliveCountMax 3

  # Load new keys into the running ssh-agent automatically on first use.
  AddKeysToAgent yes


# ──[ Template Reference ]─────────────────────────────────────────────────────
# Copy a block below and fill in the brackets. These are not active entries.

# — Basic host —
# Host [alias]
#   HostName [ip-or-fqdn]
#   User [username]
#   IdentityFile ~/.ssh/[key-name]
#   IdentitiesOnly yes

# — Bastion / ProxyJump —
# Reach an internal host by routing through a public-facing jump server.
# SSH opens a connection to [bastion] first, then tunnels to [target] through it.
# Host [internal-alias]
#   HostName [internal-ip]
#   User [username]
#   IdentityFile ~/.ssh/[key-name]
#   IdentitiesOnly yes
#   ProxyJump [bastion-alias]

# — Port Forwarding (local) —
# Bind a local port and forward traffic to a remote host:port via the SSH server.
# Useful for reaching a database or web UI that is only exposed on the server's
# loopback interface (e.g. localhost:5432 on the remote).
# Host [alias]
#   HostName [ip-or-fqdn]
#   User [username]
#   IdentityFile ~/.ssh/[key-name]
#   LocalForward [local-port] [remote-host]:[remote-port]

# — Port Forwarding (remote) —
# Bind a port on the *remote* server and forward traffic back to a local host:port.
# Useful for exposing a local dev server to a remote host temporarily.
# Host [alias]
#   HostName [ip-or-fqdn]
#   User [username]
#   IdentityFile ~/.ssh/[key-name]
#   RemoteForward [remote-port] localhost:[local-port]

# — SOCKS Proxy —
# Turn the SSH connection into a SOCKS5 proxy on a local port.
# Point a browser or tool at socks5://localhost:[local-port] to route traffic
# through the remote server's network.
# Host [alias]
#   HostName [ip-or-fqdn]
#   User [username]
#   IdentityFile ~/.ssh/[key-name]
#   DynamicForward [local-port]


