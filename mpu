#!/usr/bin/env bash
# =============================================================================
# Script Name: mpu
# Description: Mac Package Updater — updates and upgrades Homebrew
#              packages with visual feedback.
# Author: Juan Garcia (arpatek)
# Created: 2026-02-26
# Version: 2.0
# =============================================================================

# ──[ Bash Version Check ]──────────────────────────────────────────────────────
if ((BASH_VERSINFO[0] < 4)); then
  printf "mpu requires bash 4 or higher (detected: %s)\n" "$BASH_VERSION" >&2
  exit 1
fi

set -eo pipefail

# ──[ Paths ]───────────────────────────────────────────────────────────────────
# macOS ships BSD readlink which lacks -f; use Python as a portable fallback
_resolve_path() {
  python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" \
    2>/dev/null || readlink -f "$1" 2>/dev/null || printf '%s\n' "$1"
}
DOTFILES_DIR="$(cd "$(dirname "$(_resolve_path "${BASH_SOURCE[0]}")")" && pwd)"

# ──[ Shared Utilities ]────────────────────────────────────────────────────────
source "$DOTFILES_DIR/lib.sh"

# ──[ Error Trap ]──────────────────────────────────────────────────────────────
trap 'printf "\n%s Something went wrong. Update aborted.\n" "$(FAILED)"' ERR

# ──[ Argument Parsing ]────────────────────────────────────────────────────────
VERSION="2.0"
DRY_RUN=false

usage() {
  printf "Usage: mpu [OPTIONS]\n"
  printf "Options:\n"
  printf "  -h, --help      Show this help message\n"
  printf "  -V, --version   Show version\n"
  printf "  -n, --dry-run   Print commands without executing them\n"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help)
    usage
    exit 0
    ;;
  -V | --version)
    printf "mpu %s\n" "$VERSION"
    exit 0
    ;;
  -n | --dry-run) DRY_RUN=true ;;
  *)
    printf "Unknown option: %s\n" "$1" >&2
    usage >&2
    exit 1
    ;;
  esac
  shift
done

# ──[ Dry-run Runner ]──────────────────────────────────────────────────────────
run() {
  if $DRY_RUN; then
    printf "%s [dry-run] %s\n" "$(PLUS)" "$*"
  else
    "$@"
  fi
}

# ──[ Homebrew Check ]──────────────────────────────────────────────────────────
if ! command -v brew >/dev/null 2>&1; then
  printf "%s Homebrew not found\n" "$(FAILED)"
  exit 1
fi

# ──[ Update ]──────────────────────────────────────────────────────────────────
printf "%s Initializing Update Sequence" "$(BANNER)"
for _ in {1..3}; do
  sleep 0.3
  printf "."
done
printf "\n"
sleep 0.5

printf "%s Updating Homebrew\n" "$(PLUS)"
run brew update
sleep 0.5

printf "%s Upgrading Formulae\n" "$(PLUS)"
run brew upgrade
sleep 0.5

printf "%s Upgrading Casks\n" "$(PLUS)"
run brew upgrade --cask --greedy
sleep 0.5

printf "%s Cleaning Up\n" "$(PLUS)"
run brew cleanup
sleep 0.5

printf "%s Checking for Issues\n" "$(PLUS)"
run brew doctor 2>&1 | grep -v "^Your system is ready" || true

printf "%s Update Complete\n" "$(COMPLETE)"
